/* 历史页面样式 */
.empty-box {
  text-align: center;
  padding: 80rpx 0;
}

.loading-box {
  text-align: center;
  padding: 40rpx 0;
}

.trip-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.trip-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.trip-date {
  font-size: 26rpx;
  color: #666;
}

.catch-badge {
  background: #e8f5e9;
  color: #2e7d32;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.trip-location {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.trip-weather {
  display: flex;
  gap: 16rpx;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.trip-remark {
  margin-bottom: 12rpx;
}

.trip-action {
  margin-top: 12rpx;
}

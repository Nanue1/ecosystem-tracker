<view class="container">
  <view class="header">
    <text class="title">路亚出勤记录</text>
    <text class="subtitle">生态研究追踪</text>
  </view>

  <!-- 位置信息 -->
  <view class="section">
    <view class="section-title">当前位置</view>
    <view class="location-box">
      <text wx:if="{{location}}">{{address || '正在获取地址...'}}</text>
      <text wx:else class="muted">未获取位置</text>
    </view>
    <button bindtap="getLocation" type="primary" size="mini">获取位置</button>
  </view>

  <!-- 位置坐标 -->
  <view wx:if="{{location}}" class="info-row">
    <text class="muted">坐标：{{location.latitude}}, {{location.longitude}}</text>
  </view>

  <!-- 天气信息 -->
  <view wx:if="{{weather}}" class="section">
    <view class="section-title">实时天气</view>
    <view class="weather-grid">
      <view class="weather-item">{{weather.weather}}</view>
      <view class="weather-item">{{weather.temperature}}°C</view>
      <view class="weather-item">{{weather.wind}}</view>
      <view class="weather-item">湿度 {{weather.humidity}}%</view>
    </view>
  </view>

  <!-- 潮讯信息 -->
  <view wx:if="{{tide}}" class="section">
    <view class="section-title">今日潮讯</view>
    <view class="tide-grid">
      <view>高潮：{{tide.high_tide}}</view>
      <view>低潮：{{tide.low_tide}}</view>
      <view>当前潮位：{{tide.current_level}}{{tide.unit}}</view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="section">
    <view class="section-title">备注</view>
    <input
      class="remark-input"
      placeholder="今天鱼情如何？"
      value="{{remark}}"
      bindinput="onRemarkChange"
    />
  </view>

  <!-- 出勤结果 -->
  <view wx:if="{{tripResult}}" class="result-box">
    <text class="success">出勤记录成功！</text>
    <text>记录ID: {{tripResult.id}}</text>
  </view>

  <!-- 操作按钮 -->
  <view class="actions">
    <button bindtap="recordTrip" type="primary" loading="{{loading}}" disabled="{{!location}}">
      一键出勤
    </button>
    <button wx:if="{{tripId}}" bindtap="goToCatch" type="default">
      去记录鱼货
    </button>
  </view>
</view>

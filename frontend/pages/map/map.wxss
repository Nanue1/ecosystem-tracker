/* 地图/标点页面样式 */
.empty-box,
.loading-box {
  text-align: center;
  padding: 60rpx 0;
}

.location-hint {
  margin: 12rpx 0;
}

.success-text {
  color: #4caf50;
  font-size: 24rpx;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.waypoint-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.waypoint-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.waypoint-coord {
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.waypoint-remark {
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.waypoint-date {
  font-size: 22rpx;
}

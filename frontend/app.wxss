/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
}

.container {
  padding: 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1a73e8;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.muted {
  color: #999;
  font-size: 24rpx;
}

.success {
  color: #4caf50;
}

/* 位置信息 */
.location-box {
  background: #f0f7ff;
  border-radius: 8rpx;
  padding: 16rpx;
  margin: 12rpx 0;
  min-height: 60rpx;
}

.info-row {
  padding: 8rpx 0;
}

/* 天气 */
.weather-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.weather-item {
  background: #e8f5e9;
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  color: #2e7d32;
}

/* 潮讯 */
.tide-grid {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 26rpx;
}

/* 备注 */
.remark-input {
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 结果 */
.result-box {
  background: #e8f5e9;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

/* 按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

/* 照片 */
.photo-area {
  margin: 12rpx 0;
}

.photo-preview {
  width: 300rpx;
  height: 300rpx;
  border-radius: 12rpx;
}

.photo-placeholder {
  width: 300rpx;
  height: 300rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
}

/* 输入框 */
.input {
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.picker-value {
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 12rpx;
}

/* 提交按钮 */
.submit-btn {
  margin-top: 30rpx;
}

/* 鱼货记录项 */
.catch-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
